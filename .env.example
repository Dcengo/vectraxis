# Vectraxis Configuration
# Copy to .env and fill in your API keys

# LLM Provider API Keys (set at least one to enable real LLM calls)
VECTRAXIS_OPENAI_API_KEY=
VECTRAXIS_ANTHROPIC_API_KEY=
VECTRAXIS_XAI_API_KEY=

# Default model for queries (e.g. gpt-4o-mini, claude-sonnet-4-20250514, grok-2)
VECTRAXIS_DEFAULT_MODEL=gpt-4o-mini

# Embedding model
VECTRAXIS_EMBEDDING_MODEL=text-embedding-3-small
VECTRAXIS_EMBEDDING_DIMENSION=1536

# Application
VECTRAXIS_APP_NAME=Vectraxis
VECTRAXIS_DEBUG=false
VECTRAXIS_LOG_LEVEL=INFO

# Database
VECTRAXIS_DATABASE_URL=postgresql+asyncpg://vectraxis:vectraxis@localhost:4343/vectraxis
